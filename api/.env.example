API_PORT=3001
DATABASE_PATH=./data/quietcare.db

# Comma-separated origins for browser (SPA) when not using same host. Required for cross-origin cookies in production.
# CORS_ORIGIN=https://app.example.com

SESSION_SECRET=change-me-in-production
# Optional: reverse-proxy hop count (default 1). Increase only if you have multiple proxies.
# TRUST_PROXY_HOPS=1

TUYA_BASE_URL=https://openapi.tuyaus.com
# IoT Core → Cloud → your project: "Access ID" / "Access Secret"
TUYA_ACCESS_KEY=
TUYA_SECRET_KEY=
TUYA_DEVICE_STATUS_MODE=legacy
# Noise level datapoint on CO2 / mic devices (maps to "decibels" in the app)
TUYA_DECIBEL_DP_CODE=co2_value
TUYA_DECIBEL_SCALE=1
# result.* unix field used to skip duplicate snapshots (update_time changes when status updates; active_time is usually fixed per device)
TUYA_DEDUP_TIME_FIELD=update_time
TUYA_POLL_INTERVAL_MS=30000
