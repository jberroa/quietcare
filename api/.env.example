API_PORT=3001
DATABASE_PATH=./data/quietcare.db

# Comma-separated origins for browser (SPA) when not using same host. Required for cross-origin cookies in production.
# CORS_ORIGIN=https://app.example.com

SESSION_SECRET=change-me-in-production
# Optional: reverse-proxy hop count (default 1). Increase only if you have multiple proxies.
# TRUST_PROXY_HOPS=1

# Live noise readings: MQTT broker (devices publish JSON with device_id, timestamp, decibel).
# Works with Eclipse Mosquitto and any MQTT 3.1.1/5 broker the `mqtt` npm client supports.
# Mosquitto default (no TLS): port 1883 — e.g. same machine:
# MQTT_URL=mqtt://127.0.0.1:1883
# TLS (if you configured mosquitto listener 8883 + capath / certfile / keyfile):
# MQTT_URL=mqtts://your-broker:8883
# If Mosquitto uses password_file / allow_anonymous false, set MQTT_USERNAME / MQTT_PASSWORD to match.
# MQTT_USERNAME=
# MQTT_PASSWORD=
# Comma-separated topics; default if unset: sound/#
# MQTT_TOPICS=sound/#
# JSON field for level in dB (default: decibel)
# MQTT_PAYLOAD_DECIBEL_KEY=decibel
