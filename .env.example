# SPA (Vite) — copy to .env locally. See api/.env.example for the API server.

# When the API has its own URL (SPA and API on different hosts), set this for production
# builds and rebuild the SPA. No trailing slash. Example: https://api.yourdomain.com
# Local dev: leave unset so /api is proxied to the API (see VITE_API_PROXY_TARGET).
# Docker/Coolify: pass the same as a build arg / build-time env VITE_API_BASE_URL.
# VITE_API_BASE_URL=https://api.yourdomain.com

# Dev only: where Vite proxies /api (default http://127.0.0.1:3001)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Optional: Gemini (baked into client bundle at build time)
# GEMINI_API_KEY=
